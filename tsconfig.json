{
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"**/.server/**/*.ts",
		"**/.server/**/*.tsx",
		"**/.client/**/*.ts",
		"**/.client/**/*.tsx"
	],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["vite/client"],
		"isolatedModules": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"target": "ES2022",
		"strict": true,
		"allowJs": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": ".",
		"noImplicitReturns": true,
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"paths": {
			"~/*": ["./app/*"]
		},
		// Required for NestJS @Module(), @Injectable(), and @Inject() decorators.
		// emitDecoratorMetadata enables Reflect.metadata calls that NestJS DI uses
		// to resolve constructor-injected types at runtime.
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		// Vite takes care of building everything, not tsc.
		"noEmit": true
	},
	"watch": true
}
